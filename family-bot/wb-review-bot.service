[Unit]
Description=WB Review Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/claudeclaw/family-bot
EnvironmentFile=/root/claudeclaw/family-bot/.env
ExecStart=/usr/bin/python3 /root/claudeclaw/family-bot/bot.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
