# ──────────────────────────────────────────────
# ClaudeClaw — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Telegram (required) ────────────────────────
# Get from @BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID
# Start the bot and send /chatid to get this
ALLOWED_CHAT_ID=

# ── Voice: STT via Groq (optional) ────────────
# Free tier at https://console.groq.com
# Enables transcription of voice notes you send
GROQ_API_KEY=

# ── Voice: TTS via ElevenLabs (optional) ──────
# Free tier at https://elevenlabs.io
# Enables audio voice replies
ELEVENLABS_API_KEY=
# Your chosen voice ID (from ElevenLabs voice library)
ELEVENLABS_VOICE_ID=

# ── Logging ────────────────────────────────────
# Log level: trace | debug | info | warn | error
# LOG_LEVEL=info
