    "name": "WF-01: Telegram Inbound Router",
    "description": null,
    "active": true,
    "isArchived": false,
    "nodes": [
        {
            "parameters": {
                "updates": [
                    "message",
                    "callback_query"
                ]
            },
            "id": "01-trigger",
            "name": "TelegramTrigger",
            "type": "n8n-nodes-base.telegramTrigger",
            "typeVersion": 1.1,
            "position": [
                200,
                300
            ],
            "credentials": {
                "telegramApi": {
                    "id": "BUi8I5qusGpd92vZ",
                    "name": "Sofiny-Finance"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "const input = $input.first().json;\nlet messageType = 'unknown';\nlet chatId = '';\nlet text = '';\nlet callbackData = '';\nlet messageId = '';\nlet firstName = '';\n\nif (input.message) {\n  chatId = String(input.message.chat.id);\n  text = input.message.text || '';\n  messageId = String(input.message.message_id);\n  firstName = input.message.from?.first_name || '';\n  messageType = 'text';\n} else if (input.callback_query) {\n  chatId = String(input.callback_query.message.chat.id);\n  callbackData = input.callback_query.data || '';\n  messageId = String(input.callback_query.message.message_id);\n  firstName = input.callback_query.from?.first_name || '';\n  messageType = 'callback';\n}\n\nreturn [{\n  json: {\n    messageType,\n    chatId,\n    text,\n    callbackData,\n    messageId,\n    firstName,\n    rawUpdate: input\n  }\n}];"
            },
            "id": "01-parse",
            "name": "ParseUpdate",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                420,
                300
            ]
        },
        {
            "parameters": {
                "workflowId": "KKBxr8wB5INW2Wwp",
                "options": {}
            },
            "id": "01-rbac",
            "name": "RBACCheck",
            "type": "n8n-nodes-base.executeWorkflow",
            "typeVersion": 1.2,
            "position": [
                640,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const rbac = $input.first().json;\nif (!rbac.authorized) {\n  return [{ json: { ...rbac, route: 'unauthorized' } }];\n}\nconst msgType = rbac.messageType;\nconst text = (rbac.text || '').toLowerCase().trim();\nconst cb = rbac.callbackData || '';\nlet route = 'text';\nif (msgType === 'callback') {\n  const action = cb.split(':')[0];\n  if (['confirm','reject','edit'].includes(action)) route = 'confirm';\n} else if (text === '/start' || text === '/help') {\n  route = 'help';\n}\nreturn [{ json: { ...rbac, route } }];"
            },
            "id": "01-route",
            "name": "DetermineRoute",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                860,
                300
            ]
        },
