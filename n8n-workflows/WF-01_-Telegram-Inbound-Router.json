        {
            "parameters": {
                "chatId": "={{ $json.chatId }}",
                "text": "\ud83d\udc4b \u041f\u0440\u0438\u0432\u0435\u0442, {{ $json.firstName }}!\n\n\u042f \u0444\u0438\u043d\u0430\u043d\u0441\u043e\u0432\u044b\u0439 \u0431\u043e\u0442 Sofiny.\n\n\u041e\u0442\u043f\u0440\u0430\u0432\u044c \u0444\u0438\u043d\u0430\u043d\u0441\u043e\u0432\u0443\u044e \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u044e \u0442\u0435\u043a\u0441\u0442\u043e\u043c, \u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440:\n\u00ab\u041e\u043f\u043b\u0430\u0442\u0430 \u0437\u0430 \u0442\u043a\u0430\u043d\u044c 150000 \u0441\u043e \u0441\u0447\u0435\u0442\u0430 Sofiny \u0420\u0421\u00bb\n\n\u042f \u0440\u0430\u0441\u043f\u043e\u0437\u043d\u0430\u044e \u0438 \u043f\u043e\u043f\u0440\u043e\u0448\u0443 \u043f\u043e\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u0442\u044c.",
